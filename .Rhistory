install.packages(c("tidyverse", "ComplexUpset"))
library(tidyverse)
library(ComplexUpset)
make_upset_data <- function(named_vector) {
# Extract all unique set names
all_sets <- named_vector %>%
names() %>%
str_split(" and ") %>%
unlist() %>%
unique()
# Build membership rows
df <- map_dfr(names(named_vector), function(combo) {
members <- str_split(combo, " and ")[[1]]
tibble(
combination = combo,
count = named_vector[[combo]]
) %>%
bind_cols(
tibble(!!!set_names(
map(all_sets, ~ as.integer(.x %in% members)),
all_sets
))
)
})
return(df)
}
experiment_data <- c(
"Experiment on Existing Models" = 80,
"Experiment on New Models" = 2,
"Benchmark / Dataset" = 7,
"Experiment on Existing Models and Experiment on New Models" = 3,
"Experiment on Existing Models and Benchmark / Dataset" = 11,
"Experiment on New Models and Benchmark / Dataset" = 0,
"Experiment on Existing Models and Experiment on New Models and Benchmark / Dataset" = 0
)
exp_df <- make_upset_data(experiment_data)
upset(
exp_df,
intersect = colnames(exp_df)[!(colnames(exp_df) %in% c("combination", "count"))],
base_annotations = list(
'Intersection size' = intersection_size(aes(y = count))
)
)
install.packages(c("tidyverse", "UpSetR"))
library(tidyverse)
library(UpSetR)
experiment_data <- c(
"Experiment on Existing Models" = 80,
"Experiment on New Models" = 2,
"Benchmark / Dataset" = 7,
"Experiment on Existing Models and Experiment on New Models" = 3,
"Experiment on Existing Models and Benchmark / Dataset" = 11,
"Experiment on New Models and Benchmark / Dataset" = 0,
"Experiment on Existing Models and Experiment on New Models and Benchmark / Dataset" = 0
)
# Convert "A and B" -> membership table with repeated rows
to_upsetr_df <- function(named_vector) {
combos <- names(named_vector)
counts <- as.integer(named_vector)
# all set names
sets <- sort(unique(unlist(strsplit(combos, " and "))))
# expand into item-level rows
rows <- map2_dfr(combos, counts, function(combo, n) {
if (n <= 0) return(NULL)
members <- strsplit(combo, " and ")[[1]]
tibble(item = seq_len(n)) %>%
mutate(combo = combo) %>%
bind_cols(as_tibble(setNames(
lapply(sets, function(s) as.integer(s %in% members)),
sets
)))
})
rows %>% select(-item, -combo)
}
upset_df <- to_upsetr_df(experiment_data)
# Plot (UpSetR expects a plain data.frame)
UpSetR::upset(as.data.frame(upset_df), sets = colnames(upset_df))
install.packages(c("tidyverse", "UpSetR"))
library(tidyverse)
library(UpSetR)
experiment_data <- c(
"Experiment on Existing Models" = 80,
"Experiment on New Models" = 2,
"Benchmark / Dataset" = 7,
"Experiment on Existing Models and Experiment on New Models" = 3,
"Experiment on Existing Models and Benchmark / Dataset" = 11,
"Experiment on New Models and Benchmark / Dataset" = 0,
"Experiment on Existing Models and Experiment on New Models and Benchmark / Dataset" = 0
)
# Convert "A and B" -> membership table with repeated rows
to_upsetr_df <- function(named_vector) {
combos <- names(named_vector)
counts <- as.integer(named_vector)
# all set names
sets <- sort(unique(unlist(strsplit(combos, " and "))))
# expand into item-level rows
rows <- map2_dfr(combos, counts, function(combo, n) {
if (n <= 0) return(NULL)
members <- strsplit(combo, " and ")[[1]]
tibble(item = seq_len(n)) %>%
mutate(combo = combo) %>%
bind_cols(as_tibble(setNames(
lapply(sets, function(s) as.integer(s %in% members)),
sets
)))
})
rows %>% select(-item, -combo)
}
upset_df <- to_upsetr_df(experiment_data)
# Plot (UpSetR expects a plain data.frame)
UpSetR::upset(as.data.frame(upset_df), sets = colnames(upset_df))
# Convert "A and B and C" = count into an UpSetR membership table (expanded rows)
to_upsetr_df <- function(named_vector) {
combos <- names(named_vector)
counts <- as.integer(named_vector)
sets <- sort(unique(unlist(strsplit(combos, " and "))))
rows <- purrr::map2_dfr(combos, counts, function(combo, n) {
if (is.na(n) || n <= 0) return(NULL)
members <- strsplit(combo, " and ")[[1]]
tibble(dummy = seq_len(n)) %>%
bind_cols(as_tibble(setNames(
lapply(sets, function(s) as.integer(s %in% members)),
sets
)))
})
as.data.frame(rows %>% select(-dummy))
}
plot_upset <- function(named_vector, mainbar_y_label = "Intersection Size") {
df <- to_upsetr_df(named_vector)
UpSetR::upset(
df,
sets = colnames(df),
mb.ratio = c(0.65, 0.35),
mainbar.y.label = mainbar_y_label
)
}
